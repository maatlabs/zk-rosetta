# Rust / Cargo build artifacts
/target

# Profiling and coverage artifacts
*.profraw
*.profdata
perf.data*

# Generated catalog site output
/dist/

# Node tooling (site search index, EVM harness toolchains)
node_modules/

# Test-vector generation intermediates (run in a scratch directory; only the
# small final artifacts are committed). The exported Solidity verifier is GPL and
# is regenerated on demand rather than vendored.
vectors/**/*.ptau
vectors/**/*.zkey
vectors/**/*.r1cs
vectors/**/*.sym
vectors/**/*.wtns
vectors/**/*_js/
vectors/**/input.json
vectors/**/verifier.sol

# Local environment and secrets (RPC endpoints, deploy keys)
.env
.env.*
!.env.example

# OS-specific files
.DS_Store

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
